#!/usr/bin/env bash
set -euo pipefail

# gotestsum generates the JUnit XML report consumed by bktec's Go runner.
go install gotest.tools/gotestsum@v1.12.0
export PATH="$(go env GOPATH)/bin:${PATH}"

if [[ -n "${BKTEC_REF:-}" ]]; then
  # shellcheck source=/dev/null
  source "${BUILDKITE_BUILD_CHECKOUT_PATH}/.buildkite/scripts/install-bktec-from-source.sh"
fi

# Run Buildkite Test Engine Client configured by the tests Buildkite plugin
bktec run
